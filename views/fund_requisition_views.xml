<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    <!-- FUND REQUISITION — Form View -->
    <record id="view_fund_requisition_form" model="ir.ui.view">
        <field name="name">nn.fund.requisition.form</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <form string="Fund Requisition">
                <header>
                    <button name="action_submit" string="Submit for Approval"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
 
                    <button name="action_gm_approve" string="GM Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="nn_fund_management.group_gm_approver,nn_fund_management.group_fund_admin"/>
 
                    <button name="action_md_approve" string="MD Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_md_approver,nn_fund_management.group_fund_admin"/>
 
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state not in ('submitted','gm_approved')"
                            groups="nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver,nn_fund_management.group_fund_admin"
                            confirm="Are you sure you want to reject this requisition?"/>
 
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('approved','closed','rejected','cancelled')"
                            confirm="Are you sure you want to cancel this requisition?"/>
 
                    <button name="action_close" string="Close Requisition"
                            type="object"
                            invisible="state != 'approved'"
                            groups="nn_fund_management.group_finance_user,nn_fund_management.group_fund_admin"
                            confirm="Close this requisition? Any unbilled amount will be released back to the project balance."/>
 
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approved,approved,closed"/>
                </header>
 
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Requisition Number"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
 
                    <!-- Remaining billable highlight -->
                    <div class="o_field_widget o_stat_buttons"
                         invisible="state not in ('approved','closed')">
                        <div class="btn btn-light o_stat_button">
                            <field name="requested_amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <span class="o_stat_text">Approved Amount</span>
                        </div>
                        <div class="btn btn-light o_stat_button">
                            <field name="total_billed" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <span class="o_stat_text">Total Billed</span>
                        </div>
                        <div class="btn btn-light o_stat_button">
                            <field name="remaining_billable" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <span class="o_stat_text">Remaining Billable</span>
                        </div>
                        <button class="btn btn-light o_stat_button" type="object"
                                name="action_view_bills" icon="fa-file-text-o">
                            <field name="bill_count"/>
                            <span class="o_stat_text">Bills</span>
                        </button>
                    </div>
 
                    <!-- Rejection reason -->
                    <div class="alert alert-danger"
                         invisible="state not in ('rejected','cancelled') or not rejection_reason">
                        <strong>Reason: </strong>
                        <field name="rejection_reason" readonly="1" nolabel="1"/>
                    </div>
 
                    <group>
                        <group string="Requisition Details">
                            <field name="project_expense_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="requested_amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="purpose" readonly="state != 'draft'"/>
                        </group>
                        <group string="Dates &amp; Requestor">
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="required_date" readonly="state != 'draft'"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="1"/>
                        </group>
                    </group>
 
                    <group string="GM Approval"
                           invisible="state not in ('gm_approved','approved','closed','rejected')">
                        <field name="gm_approver_id" readonly="1"/>
                        <field name="gm_approval_date" readonly="1"/>
                    </group>
 
                    <group string="MD Approval"
                           invisible="state not in ('approved','closed')">
                        <field name="md_approver_id" readonly="1"/>
                        <field name="md_approval_date" readonly="1"/>
                    </group>
 
                    <group string="Attachments">
                        <field name="attachment_ids" widget="many2many_binary"
                               nolabel="1" colspan="2"/>
                    </group>
 
                    <notebook>
                        <page string="Bills" name="bills">
                            <field name="bill_ids" readonly="1">
                                <list string="Bills"
                                      decoration-success="state == 'posted'"
                                      decoration-muted="state == 'cancelled'">
                                    <field name="name"/>
                                    <field name="bill_date"/>
                                    <field name="vendor"/>
                                    <field name="amount" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'posted'"
                                           decoration-warning="state == 'draft'"
                                           decoration-danger="state == 'cancelled'"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Approval History" name="approval_history">
                            <field name="approval_history_ids" readonly="1">
                                <list string="Approval History">
                                    <field name="date"/>
                                    <field name="approver_id"/>
                                    <field name="approval_level"/>
                                    <field name="decision" widget="badge"
                                           decoration-success="decision == 'approved'"
                                           decoration-warning="decision == 'submitted'"
                                           decoration-danger="decision in ('rejected','cancelled')"/>
                                    <field name="state_before"/>
                                    <field name="state_after"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>   

    <!-- FUND REQUISITION — List View  -->
    <record id="view_fund_requisition_list" model="ir.ui.view">
        <field name="name">nn.fund.requisition.list</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <list string="Fund Requisitions"
                  decoration-success="state in ('approved','closed')"
                  decoration-warning="state in ('submitted','gm_approved')"
                  decoration-danger="state in ('rejected','cancelled')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="project_expense_id"/>
                <field name="requested_by"/>
                <field name="requested_amount" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="remaining_billable" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="required_date"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('approved','closed')"
                       decoration-warning="state in ('submitted','gm_approved')"
                       decoration-info="state == 'draft'"
                       decoration-danger="state in ('rejected','cancelled')"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- FUND REQUISITION — Search View -->
    <record id="view_fund_requisition_search" model="ir.ui.view">
        <field name="name">nn.fund.requisition.search</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <search string="Fund Requisitions">
                <field name="name"/>
                <field name="project_expense_id"/>
                <field name="requested_by"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Pending Approval" name="pending"
                        domain="[('state','in',['submitted','gm_approved'])]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Closed" name="closed" domain="[('state','=','closed')]"/>
                <filter string="Rejected / Cancelled" name="rejected"
                        domain="[('state','in',['rejected','cancelled'])]"/>
                <separator/>
                <filter string="My Requests" name="my_requests"
                        domain="[('requested_by','=',uid)]"/>
                <filter string="Overdue" name="overdue"
                        domain="[('required_date','&lt;',context_today().strftime('%Y-%m-%d')),('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project / Expense" name="grp_project"
                            context="{'group_by': 'project_expense_id'}"/>
                    <filter string="Status" name="grp_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
 
    <!-- Action -->
    <record id="action_fund_requisition" model="ir.actions.act_window">
        <field name="name">Fund Requisitions</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fund_requisition_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Fund Requisition
            </p>
            <p>Request funds from a project or expense head. Bills can only be raised against approved requisitions.</p>
        </field>
    </record>
    
    </data>
    
</odoo>
