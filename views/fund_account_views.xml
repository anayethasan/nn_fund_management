<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    <!-- FUND ACCOUNT — Form View -->
        <record id="view_fund_account_form" model="ir.ui.view">
            <field name="name">nn.fund.account.form</field>
            <field name="model">nn.fund.account</field>
            <field name="arch" type="xml">
                <form string="Fund Account">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Account Name"/>
                            <h1>
                                <field name="name" placeholder="e.g. Main Bank Account"/>
                            </h1>
                        </div>
    
                        <!-- Balance Summary Bar -->
                        <div class="o_field_widget o_stat_buttons">
                            <button class="btn btn-light o_stat_button" type="object"
                                    name="action_view_incoming_funds" icon="fa-arrow-down">
                                <field name="total_received" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"/>
                                <span class="o_stat_text">Total Received</span>
                            </button>
                            <button class="btn btn-light o_stat_button" type="object"
                                    name="action_view_incoming_funds" icon="fa-unlock">
                                <field name="unassigned_balance" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"/>
                                <span class="o_stat_text">Unassigned</span>
                            </button>
                            <button class="btn btn-light o_stat_button" type="object"
                                    name="action_view_allocations" icon="fa-clock-o">
                                <field name="held_amount" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"/>
                                <span class="o_stat_text">On Hold</span>
                            </button>
                            <button class="btn btn-light o_stat_button" type="object"
                                    name="action_view_allocations" icon="fa-check-circle">
                                <field name="assigned_amount" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"/>
                                <span class="o_stat_text">Assigned</span>
                            </button>
                        </div>
    
                        <group>
                            <group string="Account Details">
                                <field name="account_type"/>
                                <field name="currency_id" options="{'no_create': True}"/>
                                <field name="company_id" options="{'no_create': True}"
                                    groups="base.group_multi_company"/>
                                <field name="active"/>
                            </group>
                            <group string="Notes">
                                <field name="description" nolabel="1" colspan="2"/>
                            </group>
                        </group>
    
                        <!-- Incoming Funds tab -->
                        <notebook>
                            <page string="Incoming Funds" name="incoming_funds">
                                <field name="incoming_fund_ids" mode="list" readonly="1">
                                    <list string="Incoming Funds" decoration-success="state == 'confirmed'"
                                        decoration-muted="state == 'cancelled'">
                                        <field name="date"/>
                                        <field name="transaction_ref"/>
                                        <field name="sender"/>
                                        <field name="amount" widget="monetary"
                                            options="{'currency_field': 'currency_id'}"/>
                                        <field name="state" widget="badge"
                                            decoration-success="state == 'confirmed'"
                                            decoration-warning="state == 'draft'"
                                            decoration-danger="state == 'cancelled'"/>
                                        <field name="currency_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Allocations" name="allocations">
                                <field name="allocation_ids" mode="list" readonly="1">
                                    <list string="Allocations" decoration-success="state == 'approved'"
                                        decoration-warning="state in ('submitted','gm_approved')"
                                        decoration-danger="state in ('rejected','cancelled')">
                                        <field name="name"/>
                                        <field name="project_expense_id"/>
                                        <field name="amount" widget="monetary"
                                            options="{'currency_field': 'currency_id'}"/>
                                        <field name="state" widget="badge"
                                            decoration-success="state == 'approved'"
                                            decoration-warning="state in ('submitted','gm_approved')"
                                            decoration-danger="state in ('rejected','cancelled')"/>
                                        <field name="currency_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- FUND ACCOUNT — List View -->
        <record id="view_fund_account_list" model="ir.ui.view">
            <field name="name">nn.fund.account.list</field>
            <field name="model">nn.fund.account</field>
            <field name="arch" type="xml">
                <list string="Fund Accounts">
                    <field name="name"/>
                    <field name="account_type"/>
                    <field name="currency_id"/>
                    <field name="total_received" widget="monetary"
                        options="{'currency_field': 'currency_id'}"/>
                    <field name="unassigned_balance" widget="monetary"
                        options="{'currency_field': 'currency_id'}"/>
                    <field name="held_amount" widget="monetary"
                        options="{'currency_field': 'currency_id'}"/>
                    <field name="assigned_amount" widget="monetary"
                        options="{'currency_field': 'currency_id'}"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <!-- FUND ACCOUNT — Search View -->
        <record id="view_fund_account_search" model="ir.ui.view">
            <field name="name">nn.fund.account.search</field>
            <field name="model">nn.fund.account</field>
            <field name="arch" type="xml">
                <search string="Fund Accounts">
                    <field name="name"/>
                    <field name="account_type"/>
                    <filter string="Bank" name="bank" domain="[('account_type','=','bank')]"/>
                    <filter string="Cash" name="cash" domain="[('account_type','=','cash')]"/>
                    <separator/>
                    <filter string="Active" name="active" domain="[('active','=',True)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Account Type" name="grp_type"
                                context="{'group_by': 'account_type'}"/>
                        <filter string="Company" name="grp_company"
                                context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_fund_account" model="ir.actions.act_window">
            <field name="name">Fund Accounts</field>
            <field name="res_model">nn.fund.account</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_fund_account_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Fund Account
                </p>
                <p>Fund accounts hold incoming funds and track unassigned, held and assigned balances.</p>
            </field>
        </record>

    </data>
    
</odoo>
