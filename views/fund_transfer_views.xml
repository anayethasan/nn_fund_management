<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    <!-- FUND TRANSFER — Form View -->
    <record id="view_fund_transfer_form" model="ir.ui.view">
        <field name="name">nn.fund.transfer.form</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <form string="Fund Transfer">
                <header>
                    <button name="action_submit" string="Submit for Approval"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
 
                    <button name="action_gm_approve" string="GM Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="nn_fund_management.group_gm_approver,nn_fund_management.group_fund_admin"/>
 
                    <button name="action_md_approve" string="MD Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'gm_approved'"
                            groups="nn_fund_management.group_md_approver,nn_fund_management.group_fund_admin"/>
 
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state not in ('submitted','gm_approved')"
                            groups="nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver,nn_fund_management.group_fund_admin"
                            confirm="Are you sure you want to reject this transfer request?"/>
 
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('approved','rejected','cancelled')"
                            confirm="Are you sure you want to cancel this transfer?"/>
 
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approved,approved"/>
                </header>
 
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Transfer Number"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
 
                    <!-- Info: amount on hold while pending -->
                    <div class="alert alert-info"
                         invisible="state not in ('submitted','gm_approved')">
                        <i class="fa fa-lock"/> The transfer amount is on hold in
                        <field name="source_id" readonly="1" nolabel="1" class="oe_inline"/>
                        and cannot be spent or transferred again until this request is resolved.
                    </div>
 
                    <!-- Rejection reason -->
                    <div class="alert alert-danger"
                         invisible="state not in ('rejected','cancelled') or not rejection_reason">
                        <strong>Reason: </strong>
                        <field name="rejection_reason" readonly="1" nolabel="1"/>
                    </div>
 
                    <group>
                        <group string="Transfer Details">
                            <field name="source_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="destination_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Request Information">
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="1"/>
                        </group>
                    </group>
 
                    <group string="Reason">
                        <field name="reason" nolabel="1" colspan="2"
                               readonly="state != 'draft'"/>
                    </group>
 
                    <group string="GM Approval"
                           invisible="state not in ('gm_approved','approved','rejected')">
                        <field name="gm_approver_id" readonly="1"/>
                        <field name="gm_approval_date" readonly="1"/>
                    </group>
 
                    <group string="MD Approval"
                           invisible="state != 'approved'">
                        <field name="md_approver_id" readonly="1"/>
                        <field name="md_approval_date" readonly="1"/>
                    </group>
 
                    <notebook>
                        <page string="Approval History" name="approval_history">
                            <field name="approval_history_ids" readonly="1">
                                <list string="Approval History">
                                    <field name="date"/>
                                    <field name="approver_id"/>
                                    <field name="approval_level"/>
                                    <field name="decision" widget="badge"
                                           decoration-success="decision == 'approved'"
                                           decoration-warning="decision == 'submitted'"
                                           decoration-danger="decision in ('rejected','cancelled')"/>
                                    <field name="state_before"/>
                                    <field name="state_after"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- FUND TRANSFER — List View -->
    <record id="view_fund_transfer_list" model="ir.ui.view">
        <field name="name">nn.fund.transfer.list</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <list string="Fund Transfers"
                  decoration-success="state == 'approved'"
                  decoration-warning="state in ('submitted','gm_approved')"
                  decoration-danger="state in ('rejected','cancelled')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="source_id"/>
                <field name="destination_id"/>
                <field name="requested_by"/>
                <field name="amount" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state in ('submitted','gm_approved')"
                       decoration-info="state == 'draft'"
                       decoration-danger="state in ('rejected','cancelled')"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

     <!-- FUND TRANSFER — Search View    -->
     <record id="view_fund_transfer_search" model="ir.ui.view">
        <field name="name">nn.fund.transfer.search</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <search string="Fund Transfers">
                <field name="name"/>
                <field name="source_id"/>
                <field name="destination_id"/>
                <field name="requested_by"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Pending Approval" name="pending"
                        domain="[('state','in',['submitted','gm_approved'])]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Rejected / Cancelled" name="rejected"
                        domain="[('state','in',['rejected','cancelled'])]"/>
                <separator/>
                <filter string="My Requests" name="my_requests"
                        domain="[('requested_by','=',uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Source" name="grp_source"
                            context="{'group_by': 'source_id'}"/>
                    <filter string="Destination" name="grp_dest"
                            context="{'group_by': 'destination_id'}"/>
                    <filter string="Status" name="grp_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
 
    <!-- Action -->
    <record id="action_fund_transfer" model="ir.actions.act_window">
        <field name="name">Fund Transfers</field>
        <field name="res_model">nn.fund.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fund_transfer_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Fund Transfer
            </p>
            <p>Transfer funds between projects or expense heads. Source and destination must be different.</p>
        </field>
    </record>
    
    </data>
    
</odoo>
