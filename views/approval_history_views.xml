<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
    <!-- APPROVAL HISTORY — List View (read-only audit log) -->
    <record id="view_approval_history_list" model="ir.ui.view">
        <field name="name">nn.approval.history.list</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <list string="Approval History" create="false" edit="false" delete="false"
                  decoration-success="decision == 'approved'"
                  decoration-warning="decision == 'submitted'"
                  decoration-danger="decision in ('rejected','cancelled')">
                <field name="date"/>
                <field name="res_model"/>
                <field name="res_name"/>
                <field name="approver_id"/>
                <field name="approval_level"/>
                <field name="decision" widget="badge"
                       decoration-success="decision == 'approved'"
                       decoration-warning="decision == 'submitted'"
                       decoration-danger="decision in ('rejected','cancelled')"/>
                <field name="state_before"/>
                <field name="state_after"/>
                <field name="amount" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="fund_account_id"/>
                <field name="project_expense_id"/>
                <field name="comment"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
 
    <!-- Form (read-only — audit records are immutable) -->
    <record id="view_approval_history_form" model="ir.ui.view">
        <field name="name">nn.approval.history.form</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <form string="Approval History Entry" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Document">
                            <field name="res_model" readonly="1"/>
                            <field name="res_name" readonly="1"/>
                            <field name="res_id" readonly="1"/>
                        </group>
                        <group string="Action">
                            <field name="approver_id" readonly="1"/>
                            <field name="approval_level" readonly="1"/>
                            <field name="decision" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="State Change">
                            <field name="state_before" readonly="1"/>
                            <field name="state_after" readonly="1"/>
                        </group>
                        <group string="Financial Context">
                            <field name="amount" widget="monetary"
                                   options="{'currency_field': 'currency_id'}" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="fund_account_id" readonly="1"/>
                            <field name="project_expense_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Comment">
                        <field name="comment" nolabel="1" colspan="2" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
 
    <!-- Search -->
    <record id="view_approval_history_search" model="ir.ui.view">
        <field name="name">nn.approval.history.search</field>
        <field name="model">nn.approval.history</field>
        <field name="arch" type="xml">
            <search string="Approval History">
                <field name="res_name"/>
                <field name="approver_id"/>
                <field name="fund_account_id"/>
                <field name="project_expense_id"/>
                <filter string="Approved" name="approved" domain="[('decision','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('decision','=','rejected')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('decision','=','cancelled')]"/>
                <separator/>
                <filter string="Allocations" name="alloc"
                        domain="[('res_model','=','nn.fund.allocation')]"/>
                <filter string="Requisitions" name="req"
                        domain="[('res_model','=','nn.fund.requisition')]"/>
                <filter string="Transfers" name="trans"
                        domain="[('res_model','=','nn.fund.transfer')]"/>
                <group expand="0" string="Group By">
                    <filter string="Approver" name="grp_approver"
                            context="{'group_by': 'approver_id'}"/>
                    <filter string="Decision" name="grp_decision"
                            context="{'group_by': 'decision'}"/>
                    <filter string="Document Type" name="grp_model"
                            context="{'group_by': 'res_model'}"/>
                    <filter string="Date" name="grp_date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>
 
    <!-- Action -->
    <record id="action_approval_history" model="ir.actions.act_window">
        <field name="name">Approval History</field>
        <field name="res_model">nn.approval.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_approval_history_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No approval records yet
            </p>
            <p>All approval actions on allocations, requisitions and transfers are logged here automatically.</p>
        </field>
    </record>
        
    </data>
    
</odoo>
